# ── Output ────────────────────────────────────────────────────────────────────
# Folder where individual CSV files will be written (one per brand/model/year)
OUTPUT_DIR=./output

# Path to the CSV file containing your list of combinations to scrape
COMBINATIONS_FILE=combinations.csv

# File that tracks which combinations have already been completed.
# Delete this file to force a full re-scrape from scratch.
PROGRESS_FILE=progress.json

# ── Timing (all values in seconds) ────────────────────────────────────────────
# Random delay between page requests WITHIN a single combination
MIN_DELAY=3.5
MAX_DELAY=7.0

# Random delay BETWEEN combinations (give the server a longer rest)
COMBO_DELAY_MIN=10.0
COMBO_DELAY_MAX=18.0

# How long to wait when a page returns no data (likely rate-limited)
RATE_LIMIT_WAIT=60.0

# How many times to retry a page before giving up
MAX_RETRIES=3

# ── Browser ───────────────────────────────────────────────────────────────────
# Headed mode is harder for bot-detection scripts to fingerprint than headless.
# On a server without a display, run the script under Xvfb (xvfb-run python scraper.py)
# and keep this set to false.
HEADLESS=false
